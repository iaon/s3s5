# s3s5-server environment template.
#
# The package installs this file as /etc/s3s5/s3s5-server.env with mode 0600.
# Fill in credentials and policy, then enable/start the service explicitly:
#
#   systemctl enable --now s3s5-server
#
# The package post-install scripts intentionally do not enable or start the
# service by default.

# Provider preset: aws, yandex, minio, custom. Leave empty for auto-detection.
S3S5_PROVIDER=aws

# S3 bucket and key prefix.
S3S5_BUCKET=
S3S5_PREFIX=s3s5

# S3 region and optional endpoint override.
S3S5_REGION=us-east-1
# AWS_REGION=us-east-1
S3S5_ENDPOINT=
S3S5_FORCE_PATH_STYLE=false

# S3 credentials. Prefer S3S5_* names; AWS_* and YC_* aliases are also supported
# by the Go S3 client.
S3S5_ACCESS_KEY_ID=
S3S5_SECRET_ACCESS_KEY=
S3S5_SESSION_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# YC_ACCESS_KEY_ID=
# YC_SECRET_ACCESS_KEY=
# YC_SESSION_TOKEN=

# Payload crypto. S3S5_PSK must be at least 16 characters unless insecure local
# testing mode is enabled.
S3S5_PSK=
# S3S5_PSK_ENV=S3S5_PSK
S3S5_INSECURE_NO_CRYPTO=false

# Transport tuning. Durations use Go syntax: 50ms, 2s, 2m.
S3S5_CHUNK_SIZE=65536
S3S5_POLL_MIN=50ms
S3S5_POLL_MAX=2s
S3S5_WINDOW_CHUNKS=16
S3S5_IDLE_TIMEOUT=2m
S3S5_LOG_LEVEL=info

# Server egress policy.
# Comma-separated allow/deny rules. Examples:
#   S3S5_ALLOW_TARGETS=example.com:443,*.example.org,203.0.113.0/24
#   S3S5_DENY_TARGETS=metadata.google.internal,169.254.169.254
S3S5_ALLOW_TARGETS=
S3S5_DENY_TARGETS=
S3S5_ALLOW_PRIVATE=false
S3S5_ALLOW_UNRESTRICTED_EGRESS=false

# Server limits.
S3S5_MAX_SESSIONS=32
S3S5_MAX_BYTES_PER_SESSION=1073741824
S3S5_CONNECT_TIMEOUT=10s

# Extra raw CLI arguments appended after the generated arguments.
# Keep empty unless you need a flag not represented above.
S3S5_EXTRA_ARGS=
